{
  "name": "smart-traiding",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "alerts": "tsx scripts/run-alert-worker.ts",
    "alerts:dev": "tsx --watch scripts/run-alert-worker.ts",
    "telegram:test": "tsx scripts/test-telegram.ts",
    "news:api": "tsx scripts/run-news-server.ts",
    "news:worker": "tsx scripts/run-news-worker.ts",
    "news:poll": "tsx scripts/news-manual-poll.ts",
    "news:test-telegram": "node -e \"fetch((process.env.VITE_NEWS_API_BASE||'http://localhost:8787')+'/api/v1/news/test-telegram',{method:'POST'}).then(r=>r.text()).then(console.log)\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name news_engine_init"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.36.0",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
