# App mode
VITE_MARKET_API_KEY=
VITE_MARKET_DATA_MODE=live

# News Intelligence Engine
DATABASE_URL="file:./prisma/news-engine.db"
NEWS_API_PORT=8787
NEWS_POLL_INTERVAL_MS=120000
NEWS_IMPACT_THRESHOLD=60
NEWS_DEDUPE_WINDOW_MINUTES=180
NEWS_MAX_TELEGRAM_RETRIES=3
NEWS_MAX_ALERTS_PER_POLL=5
NEWS_INCLUDE_MARKET_WIDE=true

# Feeds
FINNHUB_API_KEY=
# Telegram vars are reused from existing project env (do not duplicate here)

# Frontend -> backend API base
VITE_NEWS_API_BASE=http://localhost:8787
